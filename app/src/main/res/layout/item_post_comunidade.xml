<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/bgBarra"
    android:layout_marginBottom="12dp"
    android:padding="16dp"
    android:elevation="2dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">

        <ImageView
            android:id="@+id/perfil"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:src="@drawable/perfil_beea"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/perfil"
            android:layout_toStartOf="@id/data_post"
            android:layout_centerVertical="true"
            android:layout_marginStart="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/nome_usuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="Anitta"
                android:textStyle="bold"
                android:textColor="@color/txtPrimary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/cargo_usuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                tools:text="Admin"
                android:textColor="@color/txtPrimary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/fundo_aba_ativa"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/data_post"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            tools:text="24/05  19:53"
            android:layout_marginEnd="10dp"
            android:textColor="#94A3B8"
            android:textSize="12sp" />

    </RelativeLayout>

    <TextView
        android:id="@+id/conteudo_post"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:text="texto pra eu testar se o layout ta bonitinho ou se isso aqui parece um circo"
        android:textColor="@color/txtPrimary"
        android:textSize="14sp"
        android:layout_marginBottom="16dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E2E8F0"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:id="@+id/barra_botoes">

        <LinearLayout
            android:id="@+id/layout_curtir"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginEnd="24dp"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:onClick="curtir">

            <ImageView
                android:id="@+id/botaoCurtir"
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:src="@drawable/curtida"
                android:layout_marginEnd="4dp"
                app:tint="@color/txtPrimary"/>

            <TextView
                android:id="@+id/contador_curtidas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="86"
                android:textColor="@color/txtPrimary"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_comentar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:onClick="comentar">

            <ImageView
                android:id="@+id/botaoComentar"
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:src="@drawable/comentario"
                android:layout_marginEnd="4dp"
                app:tint="@color/txtPrimary" />

            <TextView
                android:id="@+id/contador_comentarios"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="24"
                android:textColor="@color/txtPrimary"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>
</LinearLayout>