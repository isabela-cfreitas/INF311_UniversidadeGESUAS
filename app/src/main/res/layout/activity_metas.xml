<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgTela"
    tools:context=".MetasActivity">

    <LinearLayout
        android:id="@+id/barra_superior_post"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@color/bgBarra"
        android:layout_alignParentTop="true">

        <ImageButton
            android:id="@+id/voltar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/back_arrow"
            app:tint="@color/txtPrimary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:onClick="voltar"
            android:contentDescription="Voltar" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="COMO GANHAR PONTOS"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/txtPrimary" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/barra_superior_post"
        android:layout_above="@id/barra_gesuas_rodape">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/campo_texto"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Enviar um comentário na aula"
                    android:textSize="16sp"
                    android:textColor="@color/txtPrimary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+50 pts"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/verde2" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/campo_texto"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Emitir um certificado"
                    android:textSize="16sp"
                    android:textColor="@color/txtPrimary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+100 pts"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/verde2" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/campo_texto"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Concluir uma aula"
                    android:textSize="16sp"
                    android:textColor="@color/txtPrimary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+10 pts"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/verde2" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/campo_texto"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Iniciar um novo curso"
                    android:textSize="16sp"
                    android:textColor="@color/txtPrimary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+10 pts"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/verde2" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/campo_texto"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Atingir 50% de conclusão do curso"
                    android:textSize="16sp"
                    android:textColor="@color/txtPrimary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+25 pts"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/verde2" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/campo_texto"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Atingir 90% de conclusão do curso"
                    android:textSize="16sp"
                    android:textColor="@color/txtPrimary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+25 pts"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/verde2" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/campo_texto"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Concluir um curso integralmente"
                    android:textSize="16sp"
                    android:textColor="@color/txtPrimary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+100 pts"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/verde2" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/barra_gesuas_rodape"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:background="@color/azul"
        android:gravity="center"
        android:layout_alignParentBottom="true">

        <ImageView
            android:layout_width="90dp"
            android:layout_height="36dp"
            android:src="@drawable/logo_universidade_gesuas_branca"
            android:contentDescription="Logo GESUAS" />
    </LinearLayout>

</RelativeLayout>