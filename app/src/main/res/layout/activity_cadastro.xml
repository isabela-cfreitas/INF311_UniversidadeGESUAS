<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">
    <RelativeLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:context=".CadastroActivity">
        <LinearLayout
            android:id="@+id/conjunto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_centerHorizontal="true"
            android:gravity="center_horizontal"
            android:layout_marginTop="40dp">
            <ImageView
                android:id="@+id/logo_GESUAS"
                android:layout_width="266dp"
                android:layout_height="88dp"
                android:src="@drawable/Logo_Universidade_GESUAS"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/Poppins_SemiBold"
                android:text="Crie uma conta do Universidade GESUAS"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/infCad"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_below="@id/conjunto"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="20dp">
            <TextView
                android:id="@+id/nome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="19dp"
                android:text="Nome"/>
            <EditText
                android:id="@+id/nome_res"
                android:layout_marginTop="3dp"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:background="@drawable/campo_texto"
                android:hint="Nome Completo" />
            <TextView
                android:id="@+id/nascimento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textSize="19dp"
                android:text="Data de nascimento"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">
                <EditText
                    android:id="@+id/dia_res"
                    android:layout_marginTop="3dp"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="38dp"
                    android:background="@drawable/campo_texto"
                    android:layout_marginEnd="8dp"
                    android:hint="Dia" />
                <EditText
                    android:id="@+id/mes_res"
                    android:layout_marginTop="3dp"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="38dp"
                    android:background="@drawable/campo_texto"
                    android:layout_marginEnd="8dp"
                    android:hint="Mês" />
                <EditText
                    android:id="@+id/ano_res"
                    android:layout_marginTop="3dp"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="38dp"
                    android:background="@drawable/campo_texto"
                    android:hint="Ano" />
            </LinearLayout>

            <TextView
                android:id="@+id/cpf"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="19dp"
                android:layout_marginTop="10dp"
                android:text="Cadastro de Pessoa Física (CPF)"/>
            <EditText
                android:id="@+id/cpf_res"
                android:layout_marginTop="3dp"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:background="@drawable/campo_texto"
                android:hint="CPF" />

            <TextView
                android:id="@+id/email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="19dp"
                android:layout_marginTop="10dp"
                android:text="Email"/>
            <EditText
                android:id="@+id/email_res"
                android:layout_marginTop="3dp"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:background="@drawable/campo_texto"
                android:hint="Email" />

            <TextView
                android:id="@+id/senha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="19dp"
                android:layout_marginTop="10dp"
                android:text="Senha"/>
            <EditText
                android:id="@+id/senha_res"
                android:layout_marginTop="3dp"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:background="@drawable/campo_texto"
                android:hint="Senha" />

            <TextView
                android:id="@+id/senha_conf"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="19dp"
                android:layout_marginTop="10dp"
                android:text="Confirme sua senha"/>
            <EditText
                android:id="@+id/senha_conf_res"
                android:layout_marginTop="3dp"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:background="@drawable/campo_texto"
                android:hint="Confirme sua senha" />
        </LinearLayout>

        <Button
            android:id="@+id/criar_conta"
            android:layout_width="230dp"
            android:layout_height="wrap_content"
            android:layout_below="@id/infCad"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="20dp"
            style="@style/botao1"
            android:text="Criar conta"/>

    </RelativeLayout>
</ScrollView>