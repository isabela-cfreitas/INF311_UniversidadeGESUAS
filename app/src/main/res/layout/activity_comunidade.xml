<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F5F9"
    tools:context=".ComunidadeActivity">

    <LinearLayout
        android:id="@+id/barra_superior"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="60dp"
        android:background="@color/azul"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_alignParentTop="true">

        <ImageView
            android:id="@+id/foto_perfil"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/perfil_beea" />

        <EditText
            android:id="@+id/busca"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="42dp"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:background="@drawable/campo_texto"
            android:hint="O que você está procurando hoje?"
            android:textSize="16sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:inputType="text" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/barra_superior"
        android:layout_above="@id/bloco_rodape_total">

        <LinearLayout
            android:id="@+id/posts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp" />
    </ScrollView>

    <LinearLayout
        android:id="@+id/bloco_rodape_total"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentBottom="true"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/barra_navegacao"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="#FFFFFF"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/home"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_weight="1"
                android:src="@drawable/home"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:onClick="navegar"/>

            <ImageButton
                android:id="@+id/ranking"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_weight="1"
                android:src="@drawable/ranking"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:onClick="navegar"/>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <View
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_gravity="center"
                    android:background="@drawable/fundo_aba_ativa" />

                <ImageButton
                    android:id="@+id/comunidade"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_gravity="center"
                    android:src="@drawable/community"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:onClick="navegar"/>
            </FrameLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:background="@color/azul"
            android:gravity="center">

            <ImageView
                android:layout_width="90dp"
                android:layout_height="36dp"
                android:src="@drawable/logo_universidade_gesuas_branca"
                android:contentDescription="Logo GESUAS" />
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>