<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bgBarra"
    android:layout_marginBottom="12dp"
    android:padding="16dp"
    android:elevation="2dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/position_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="1º"
                android:textStyle="bold"
                android:textColor="@color/txtPrimary"
                android:textSize="35dp" />

            <ImageView
                android:id="@+id/perfil"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/perfil_beea"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:orientation="vertical"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/nome_usuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="Anitta"
                android:textStyle="bold"
                android:textColor="@color/txtPrimary"
                android:textSize="15dp" />

            <TextView
                android:id="@+id/cargo_usuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                tools:text="Admin"
                android:textColor="@color/txtPrimary"
                android:textSize="15dp"
                android:textStyle="bold"
                android:background="@drawable/fundo_aba_ativa"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/pontos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            tools:text="X Pontos"
            android:textStyle="bold"
            android:layout_marginEnd="10dp"
            android:textColor="@color/txtPrimary"
            android:textSize="20dp" />

    </RelativeLayout>
</LinearLayout>