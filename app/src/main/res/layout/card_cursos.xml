<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="160dp"
    android:layout_height="160dp"
    android:layout_marginEnd="10dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="4dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Capa do curso -->
        <ImageView
            android:id="@+id/imgCurso"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="@string/capaDescricao"
            android:src="@color/azul"/>

        <!-- Gradiente escuro na parte inferior para legibilidade -->
        <View
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_alignParentBottom="true"
            android:background="@drawable/gradiente_escuro_bottom"/>

        <!-- Nome do curso -->
        <TextView
            android:id="@+id/txtTituloCurso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="30dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="5dp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="12sp"
            tools:text="Ética e sigilo no cotidiano"
            xmlns:tools="http://schemas.android.com/tools"/>

        <!-- Data e hora -->
        <LinearLayout
            android:id="@+id/chipDataHora"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_alignParentStart="true"
            android:orientation="horizontal"
            android:padding="8dp">
            <TextView
                    android:id="@+id/txtDataCurso"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chip_data"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="11sp"
                    tools:text="09/04"
                    xmlns:tools="http://schemas.android.com/tools"/>

            <TextView
                android:id="@+id/txtHoraCurso"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_chip_data"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="11sp"
                tools:text="09h00"
                xmlns:tools="http://schemas.android.com/tools"/>
        </LinearLayout>

    </RelativeLayout>

</androidx.cardview.widget.CardView>