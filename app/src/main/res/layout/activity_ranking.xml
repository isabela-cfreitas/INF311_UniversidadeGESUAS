<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
xmlns:tools="http://schemas.android.com/tools"
android:id="@+id/drawer_layout"
android:layout_width="match_parent"
android:layout_height="match_parent"
tools:context=".RankingActivity">

<RelativeLayout
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgTela">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:id="@+id/topo">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="12dp"
            android:paddingTop="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="RANKING"
                android:textStyle="bold"
                android:textSize="22sp"
                android:textColor="@color/txtPrimary" />

            <ImageView
                android:id="@+id/foto_perfil"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/perfil_beea"
                android:layout_marginEnd="4dp" />

            <ImageButton
                android:id="@+id/btn_menu"
                android:layout_width="62dp"
                android:layout_height="62dp"
                android:src="@drawable/ic_menu"
                app:tint="@color/txtPrimary"
                android:scaleType="fitCenter"
                android:padding="10dp"
                android:background="?attr/actionBarItemBackground"
                android:elevation="6dp"
                android:onClick="abrirMenu" />
        </LinearLayout>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topo"
        android:layout_above="@id/bloco_rodape_total">

        <LinearLayout
            android:id="@+id/leaderboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp" />
    </ScrollView>

    <LinearLayout
        android:id="@+id/bloco_rodape_total"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentBottom="true"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/barra_navegacao"
            android:layout_width="match_parent"
            android:layout_height="75dp"
            android:background="@color/bgBarra"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/home"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_weight="1"
                android:src="@drawable/home"
                app:tint="@color/txtPrimary"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:onClick="navegar"/>

            <ImageButton
                android:id="@+id/ranking"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_weight="1"
                android:src="@drawable/ranking"
                app:tint="@color/txtPrimary"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:onClick="navegar"/>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <View
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_gravity="center"
                    android:background="@drawable/fundo_aba_ativa" />

                <ImageButton
                    android:id="@+id/comunidade"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_gravity="center"
                    android:src="@drawable/community"
                    app:tint="@color/txtPrimary"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:onClick="navegar"/>
            </FrameLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:background="@color/azul"
            android:gravity="center">

            <ImageView
                android:layout_width="90dp"
                android:layout_height="36dp"
                android:src="@drawable/logo_universidade_gesuas_branca"
                android:contentDescription="Logo GESUAS" />
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>

<LinearLayout
    android:id="@+id/menu_lateral"
    android:layout_width="260dp"
    android:layout_height="match_parent"
    android:layout_gravity="end"
    android:background="@color/bgBarra"
    android:orientation="vertical"
    android:paddingTop="48dp"
    android:paddingHorizontal="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MENU"
        android:textStyle="bold"
        android:textSize="14sp"
        android:textColor="#747474"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/btn_menu_perfil"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:text="Meu Perfil"
        android:textColor="@color/txtPrimary"
        android:textSize="16sp"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:onClick="VerPerfil"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E5E5E5"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/btn_menu_sair"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:text="Sair da Conta"
        android:textColor="#DC2626"
        android:textSize="16sp"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:onClick="sairConta"/>

</LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>