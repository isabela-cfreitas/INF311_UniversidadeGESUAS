<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".InicioActivity">

    <RelativeLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bgTela">

        <!-- ===== BARRA SUPERIOR ===== -->
        <LinearLayout
            android:id="@+id/barra_superior"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_alignParentTop="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="@string/inicio"
                android:layout_weight="1"
                android:textStyle="bold"
                android:gravity="center_vertical"
                android:layout_marginEnd="12dp"
                android:textSize="22sp"
                android:textColor="@color/txtPrimary"
                android:paddingStart="16dp"/>

            <ImageView
                android:id="@+id/foto_perfil"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/perfil_beea" />

            <ImageButton
                android:id="@+id/btn_menu"
                android:layout_width="62dp"
                android:layout_height="62dp"
                android:src="@drawable/ic_menu"
                app:tint="@color/txtPrimary"
                android:scaleType="fitCenter"
                android:padding="10dp"
                android:background="?attr/actionBarItemBackground"
                android:elevation="6dp"
                android:onClick="abrirMenu"/>

        </LinearLayout>

        <!-- ===== RODAPÉ ===== -->
        <LinearLayout
            android:id="@+id/bloco_rodape_total"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentBottom="true"
            android:elevation="8dp">

            <LinearLayout
                android:id="@+id/barra_navegacao"
                android:layout_width="match_parent"
                android:layout_height="75dp"
                android:background="@color/bgBarra"
                android:orientation="horizontal">

                <!-- HOME -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <FrameLayout
                        android:layout_width="86dp"
                        android:layout_height="52dp">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/fundo_aba_ativa"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center">

                            <ImageButton
                                android:id="@+id/home"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/home"
                                app:tint="@color/txtPrimary"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:onClick="navegar"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/inicio"
                                android:textSize="11sp"
                                android:textColor="@color/txtPrimary"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                    </FrameLayout>

                </LinearLayout>

                <!-- RANKING -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageButton
                        android:id="@+id/ranking"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ranking"
                        app:tint="@color/txtPrimary"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:onClick="navegar"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ranking"
                        android:textSize="11sp"
                        android:textColor="@color/txtPrimary"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <!-- COMUNIDADE -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageButton
                        android:id="@+id/comunidade"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/community"
                        app:tint="@color/txtPrimary"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:onClick="navegar"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/comunidade"
                        android:textSize="11sp"
                        android:textColor="@color/txtPrimary"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:background="@color/azul"
                android:gravity="center">

                <ImageView
                    android:layout_width="90dp"
                    android:layout_height="36dp"
                    android:src="@drawable/logo_universidade_gesuas_branca"
                    android:contentDescription="@string/gesuasDescricao" />
            </LinearLayout>

        </LinearLayout>

        <!-- ===== CONTEÚDO ROLÁVEL ===== -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/barra_superior"
            android:layout_above="@id/bloco_rodape_total"
            android:fillViewport="true"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- OLÁ + BOAS VINDAS -->
                <TextView
                    android:id="@+id/ola"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="28dp"
                    android:paddingTop="8dp"
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:textColor="@color/txtPrimary"
                    android:text="@string/ola"/>

                <TextView
                    android:id="@+id/boasVindas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="28dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="8dp"
                    android:textSize="14sp"
                    android:textColor="@color/txtPrimary"
                    android:text="@string/boasVindas"/>

                <!-- CARD BEEA -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:paddingTop="50dp"
                    android:paddingBottom="10dp"
                    android:paddingEnd="16dp">

                    <View
                        android:id="@+id/backgroundCard"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:background="@drawable/bg_card_azul"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/guideline85"
                        app:layout_constraintTop_toTopOf="@+id/txtTitulo"
                        android:layout_marginTop="-20dp"
                        app:layout_constraintBottom_toBottomOf="@+id/btnComecar"
                        android:layout_marginBottom="-20dp"/>

                    <ImageView
                        android:id="@+id/beaaState"
                        android:layout_width="144dp"
                        android:layout_height="180dp"
                        android:src="@drawable/bea_init"
                        android:contentDescription="@string/beeaEstudandoDescricao"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/backgroundCard"
                        app:layout_constraintBottom_toBottomOf="@+id/backgroundCard"
                        android:layout_marginTop="-80dp"
                        android:layout_marginStart="8dp" />

                    <TextView
                        android:id="@+id/txtTitulo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/sequencia"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        android:layout_marginTop="20dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/beaaState"
                        app:layout_constraintEnd_toEndOf="@+id/backgroundCard"/>

                    <Button
                        android:id="@+id/btnComecar"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/iniciar"
                        android:textColor="@color/azul"
                        android:textStyle="bold"
                        android:backgroundTint="@color/btn_comecar_tint"
                        android:layout_marginTop="16dp"
                        android:onClick="abrirSiteGesuas"
                        app:layout_constraintTop_toBottomOf="@+id/txtTitulo"
                        app:layout_constraintStart_toStartOf="@+id/txtTitulo"
                        app:layout_constraintEnd_toEndOf="@+id/txtTitulo"/>

                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/guideline85"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_constraintGuide_percent="0.85" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- ===== SEÇÃO: CURSOS EM ANDAMENTO ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="16dp"
                    android:paddingBottom="8dp">

                    <!-- Cabeçalho da seção -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/cursosEmAndamento"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textColor="@color/txtPrimary"/>

                        <TextView
                            android:id="@+id/verTodosCursos"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/verTodos"
                            android:textColor="@color/txtLink"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground"
                            android:paddingStart="8dp"
                            android:paddingEnd="4dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"/>
                    </LinearLayout>

                    <!-- RecyclerView horizontal para os cards de curso -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerCursos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:clipToPadding="false"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/card_cursos"
                        tools:itemCount="4"/>

                </LinearLayout>

                <!-- ===== SEÇÃO: MATERIAIS COMPLEMENTARES ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="16dp"
                    android:paddingBottom="24dp">

                    <!-- Cabeçalho da seção -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/materiaisComplementares"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textColor="@color/txtPrimary"/>

                        <TextView
                            android:id="@+id/verTodosMateriais"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/verTodos"
                            android:textColor="@color/txtLink"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground"
                            android:paddingStart="8dp"
                            android:paddingEnd="4dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"/>
                    </LinearLayout>

                    <!-- RecyclerView horizontal para os cards de material complementar -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerMateriais"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:clipToPadding="false"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/card_materiais"
                        tools:itemCount="3"/>

                </LinearLayout>

            </LinearLayout>
        </ScrollView>

    </RelativeLayout>

    <LinearLayout
        android:id="@+id/menu_lateral"
        android:layout_width="260dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:paddingTop="48dp"
        android:paddingHorizontal="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MENU"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="#747474"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/btn_menu_perfil"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Meu Perfil"
            android:textColor="#000000"
            android:textSize="16sp"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            android:onClick="VerPerfil"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E5E5E5"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/btn_menu_sair"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Sair da Conta"
            android:textColor="#DC2626"
            android:textSize="16sp"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            android:onClick="sairConta"/>

    </LinearLayout>
</androidx.drawerlayout.widget.DrawerLayout>